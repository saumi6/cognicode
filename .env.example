# CogniCode Environment Configuration
# Copy this to .env and fill in your values

# Required: Your Google Gemini API key (for AI Synopsis + Semantic Search)
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Your Groq API key (for AI Test Generation)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Optional: Maximum number of test cases to generate per function (default: 10)
MAX_TEST_CASES=10

# Optional: Include edge cases in test generation (default: true)
INCLUDE_EDGE_CASES=true

# Optional: Include error/exception test cases (default: true)
INCLUDE_ERROR_CASES=true

# Optional: Directory for generated test files (default: generated_tests)
OUTPUT_DIR=generated_tests

# Optional: Enable verbose output (default: false)
VERBOSE=false